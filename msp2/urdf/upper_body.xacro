        </inertial>
    </link>

    <joint name="torso_pitch" type="revolute">
        <origin xyz="0.0 0.0 0.883471" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="torso_pitch_link" />
        <axis xyz="0.0 1.0 0.0" />
        <limit effort="100.0" velocity="5.0" lower="-1.57" upper="1.57" />
        <dynamics damping="0.1" friction="0.0" />
    </joint>

    <link name="torso_roll_link">
